    "spacing": {
      "spacingSizes": [
        {
          "slug": "s0",
          "size": "3px",
          "name": "S0"
        },
        {
          "slug": "s1",
          "size": "23px",
          "name": "S1"
        },
        {
          "slug": "s2",
          "size": "53px",
          "name": "S2"
        },
        {
          "slug": "s3",
          "size": "160px",
          "name": "S3"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--surface-default, #ffffff)",
      "text": "var(--wp--preset--color--text-body, #000000)"
