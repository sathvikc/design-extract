{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "action-primary",
          "color": "#0051c3",
          "name": "Action Primary"
        },
        {
          "slug": "action-secondary",
          "color": "#de5052",
          "name": "Action Secondary"
        },
        {
          "slug": "surface-default",
          "color": "#ffffff",
          "name": "Surface Default"
        },
        {
          "slug": "text-body",
          "color": "#000000",
          "name": "Text Body"
        }
      ]
    },
    "typography": {
      "fontSizes": [
        {
          "slug": "h1",
          "size": "60px",
          "name": "h1"
        },
        {
          "slug": "h2",
          "size": "30px",
          "name": "h2"
        },
        {
          "slug": "html",
          "size": "16px",
          "name": "html"
        },
        {
          "slug": "div",
          "size": "15px",
          "name": "div"
        },
        {
          "slug": "div",
          "size": "13px",
          "name": "div"
        }
      ],
      "fontFamilies": [
        {
          "slug": "times",
          "fontFamily": "Times, sans-serif",
          "name": "Times"
        }
      ]
